 /* wallust template - colors-rofi */

* {
active-background: #597185;
active-foreground: #F6F8FA;
normal-background: #090C0F;
normal-foreground: #F6F8FA;
urgent-background: #656E76;
urgent-foreground: #F6F8FA;

alternate-active-background: #8DA9BD;
alternate-active-foreground: #F6F8FA;
