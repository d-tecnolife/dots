alternate-urgent-background: #090C0F;
alternate-urgent-foreground: #F6F8FA;

selected-active-background: #597185;
selected-active-foreground: #090C0F;
selected-normal-background: #597185;
selected-normal-foreground: #090C0F;
selected-urgent-background: #8DA9BD;
